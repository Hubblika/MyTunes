datasource db {
    provider = "mysql"
}

model User {
    id              Int             @id @default(autoincrement())
    created_at      DateTime
    email           String          @unique
    password_hash   Bytes           @db.Binary(32)
    role            Role            @default(User)
    name            String?         @db.VarChar(64)

    sessions        Session[]
    playlists       Playlist[]
    songs           Song[]
}

model Session {
    token_hash      Bytes           @id @db.Binary(32)
    created_at      DateTime
    ip_address      Bytes?          @db.Binary(4)
    user            User            @relation(fields: [user_id], references: [id])
    user_id         Int
}



model Song {
    id              Int             @id @default(autoincrement())
    title           String
    created_at      DateTime        @db.Date
    duration        Int
    is_explicit     Boolean

    artists         User[]
    playlist_songs  OrderedSong[]
}

model Playlist {
    id              Int             @id @default(autoincrement())
    creator         User            @relation(fields: [creator_id], references: [id])
    creator_id      Int
    name            String
    created_at      DateTime        @db.Date
    description     String?         @db.Text
    is_album        Boolean         @default(false)

    songs           OrderedSong[]
}

model OrderedSong {
    playlist        Playlist        @relation(fields: [playlist_id], references: [id])
    playlist_id     Int
    song            Song            @relation(fields: [song_id], references: [id])
    song_id         Int
    added_at        DateTime
    index           Int

    @@id([playlist_id, song_id])
    @@unique([playlist_id, index])
}



enum Role {
    Admin
    Artist
    User
}
